# ─── MongoDB Atlas ───────────────────────────────────────────
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/github_finder?retryWrites=true&w=majority"

# ─── NextAuth / Auth.js ──────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# In production set this to your deployed URL, e.g. https://yourapp.vercel.app
AUTH_URL="http://localhost:3000"

# ─── GitHub OAuth App (Settings → Developer settings → OAuth Apps) ──
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# ─── GitHub API token (classic PAT, read-only scopes: public_repo, read:user) ──
# Used for server-side REST + GraphQL calls so unauthenticated rate limits
# (60/hr) become authenticated limits (5000/hr).
GITHUB_TOKEN="ghp_your_personal_access_token"
